# Database
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Backend API
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_GO_PORT=8080
NEXT_PUBLIC_USE_DIRECT_BACKEND=false
NEXT_PUBLIC_USE_MOCK=true

# DOKU Payment Gateway (SNAP API)
# Client ID = X-CLIENT-KEY / X-PARTNER-ID di header
DOKU_CLIENT_ID=BRN-0222-1777799032222
# Secret Key = HMAC-SHA512 signing untuk API request (X-SIGNATURE)
DOKU_CLIENT_SECRET=SK-zgNQt47nzv2f3sPTDPG4
# API Key / Shared Key = verify webhook notification signature
DOKU_SHARED_KEY=doku_key_3a4d17030ddd4adaa5a398f88c867556
# B2B Secret Number = untuk B2B token request
DOKU_BSN=BSN-0222-1777799032208
# Private Key = RSA signing (kosong = pakai HMAC fallback)
DOKU_PRIVATE_KEY=
# Environment: true = sandbox, false = production
DOKU_IS_SANDBOX=true
NEXT_PUBLIC_DOKU_ENVIRONMENT=sandbox

# Google OAuth
GOOGLE_CLIENT_ID=503551786622-k3uajo9c2d6om6qnqofsa3b47fvo5o6g.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
NEXT_PUBLIC_GOOGLE_CLIENT_ID=503551786622-k3uajo9c2d6om6qnqofsa3b47fvo5o6g.apps.googleusercontent.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
