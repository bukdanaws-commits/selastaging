# =============================================================================
#  .dockerignore — Exclude files from Docker build context
#
#  This reduces the build context size and avoids copying host node_modules
#  which can conflict with the container's installed dependencies.
# =============================================================================

# Git
.git
.gitignore

# Dependencies (will be installed fresh in container)
node_modules

# Build output (will be generated in container)
.next
out

# Go / Backend
# Note: Do NOT exclude 'eventku-api' or 'backend/' here — 
# Cloud Build backend pipeline needs both in the Docker context.
# backend/  — needed by backend/Dockerfile multi-stage build
# eventku-api — needed by Dockerfile.backend-simple (pre-built binary wrap)
backend/seleevent.db*
backend/server
backend/seed

# Docker
.docker

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Documentation
*.md
!README.md
agent-ctx/
download/
upload/
examples/

# Terraform
gcp/terraform/.terraform
gcp/terraform/*.tfstate*

# Misc
bsi-brand-search.json
doku-api-report.md
prisma/*.db
