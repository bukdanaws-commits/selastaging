# =============================================================================
#  Selevent — Docker Ignore (optimizes build context size)
# =============================================================================

# Dependencies
node_modules
.pnp
.pnp.*
.yarn

# Next.js build output
.next
/out

# Build artifacts
build
dist

# Environment files (will be injected at runtime in Cloud Run)
.env
.env.local
.env.production
.env.*.local

# Database files (not needed in container)
db/
*.db
*.db-journal

# Git
.git
.gitignore

# Documentation
*.md
LICENSE
agent-ctx/

# IDE / Editor
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
dev.log
server.log

# Test files
test/
coverage/

# Claude / AI tools
.claude
.z-ai-config
skills/

# Backend (separate Docker build)
backend/

# Mini services (not part of frontend container)
mini-services/

# DOKU documentation JSONs (not needed in prod)
doku-*.json

# Terraform / GCP configs (not needed in container)
gcp/terraform/

# RSA keys (injected via secrets)
keys/

# Vercel config (not used in Cloud Run)
.vercel

# Prisma — REQUIRED in Docker image for production migrations
# (schema.prisma is needed at runtime for `prisma migrate deploy`)
# prisma/

# Misc
Caddyfile
examples/
run-dev.sh
start-dev.sh
